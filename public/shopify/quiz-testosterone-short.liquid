<script>
(function() {
  function fullTakeover() {
    var quizRoot = document.getElementById('quiz-root');
    if (!quizRoot) return;
    var quizSection = quizRoot.closest('.shopify-section');
    if (quizSection) {
      document.querySelectorAll('.shopify-section').forEach(function(s) {
        if (s !== quizSection) { s.style.display = 'none'; s.style.visibility = 'hidden'; }
      });
    }
    var hideSelectors = [
      'header', 'footer', 'nav',
      '.header', '.footer', '.site-header', '.site-footer',
      '.header-wrapper', '.footer-wrapper', '#header', '#footer',
      '.announcement-bar', '[class*="announcement"]', '[id*="announcement"]',
      '.page__title', '.page-title', '.main-page-title',
      '.breadcrumb', '.breadcrumbs',
      '[class*="cookie"]', '[id*="cookie"]',
      '.shopify-section-group-header-group', '.shopify-section-group-footer-group'
    ];
    hideSelectors.forEach(function(sel) {
      document.querySelectorAll(sel).forEach(function(el) {
        if (!el.contains(quizRoot)) { el.style.display = 'none'; el.style.visibility = 'hidden'; }
      });
    });
    document.querySelectorAll('#MainContent,main,.main-content,.page__content,.page-width').forEach(function(el) {
      el.style.padding = '0'; el.style.margin = '0'; el.style.maxWidth = '100%'; el.style.width = '100%';
    });
    document.body.style.overflow = 'hidden';
  }
  fullTakeover();
  document.addEventListener('DOMContentLoaded', fullTakeover);
  setTimeout(fullTakeover, 500);
  setTimeout(fullTakeover, 1500);
})();
</script>

