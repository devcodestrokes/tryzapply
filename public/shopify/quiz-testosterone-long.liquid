{%- comment -%}
  Section: quiz-testosterone-long.liquid
  Embeds the Testosterone Long quiz via iframe from the published Lovable app.
{%- endcomment -%}

<div id="quiz-embed-testo-long" style="width:100vw;max-width:100vw;min-height:100vh;position:relative;left:50%;transform:translateX(-50%);overflow:hidden;margin:0;padding:0;">
  <iframe
    id="quiz-iframe-testo-long"
    src="https://tryzapply.lovable.app/quiz/testosterone-long"
    style="width:100%;height:100vh;border:none;display:block;"
    allow="clipboard-write"
    loading="eager"
    title="Testosterone Quiz"
  ></iframe>
</div>

<style>
  .page-title, .breadcrumbs { display: none !important; }
  #quiz-embed-testo-long { margin: 0 !important; padding: 0 !important; }
  @media (max-width: 749px) {
    #quiz-embed-testo-long { min-height: 100dvh; }
    #quiz-iframe-testo-long { height: 100dvh; }
  }
</style>

<script>
(function(){
  var iframe = document.getElementById('quiz-iframe-testo-long');
  var container = document.getElementById('quiz-embed-testo-long');
  window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'quiz-resize' && e.data.height) {
      iframe.style.height = Math.max(e.data.height, 500) + 'px';
    }
  });
  var loaded = false;
  iframe.addEventListener('load', function() { loaded = true; });
  setTimeout(function() {
    if (!loaded) {
      container.innerHTML = '<div style="text-align:center;padding:60px 20px;font-family:Inter,sans-serif;">' +
        '<h2 style="font-size:24px;margin-bottom:16px;">Quiz temporarily unavailable</h2>' +
        '<p style="color:#666;margin-bottom:24px;">Please try again in a few moments.</p>' +
        '<button onclick="location.reload()" style="padding:12px 32px;background:#1a2f6b;color:#fff;border:none;border-radius:8px;font-size:16px;cursor:pointer;">Retry</button></div>';
    }
  }, 15000);
})();
</script>

{% schema %}
{
  "name": "Testosterone Quiz (Long)",
  "settings": []
}
{% endschema %}
